<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_surface_variant">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:navigationIcon="@drawable/ic_arrow_back"
        android:padding="9dp"
        app:navigationIconTint="@android:color/white">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="19dp"
            android:text="Customer Details"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>

    </com.google.android.material.appbar.MaterialToolbar>
    <!-- ScrollView with proper padding -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingTop="8dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="5dp">

            <!-- ============= HERO / CUSTOMER GRADIENT CARD ============= -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_gradient_header"
                    android:padding="18dp">

                    <!-- Avatar + name row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvAvatarInitial"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_circle_avatar"
                            android:gravity="center"
                            android:text="R"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvCustomerName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@android:color/white"
                                android:textSize="19sp"
                                android:textStyle="bold"
                                android:text="Rahul Sharma"/>

                            <TextView
                                android:id="@+id/tvCustomerId"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="#CCFFFFFF"
                                android:textSize="13sp"
                                android:text="#LN001234"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvEmiStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_status_active"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="5dp"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:text="ACTIVE"/>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="14dp"
                        android:background="#33FFFFFF"/>

                    <!-- Loan amount + mobile row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Loan Amount"
                                android:textColor="#99FFFFFF"
                                android:textSize="12sp"/>

                            <TextView
                                android:id="@+id/tvLoanAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@android:color/white"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:text="₹5,00,000"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mobile"
                                android:textColor="#99FFFFFF"
                                android:textSize="12sp"/>

                            <TextView
                                android:id="@+id/tvMobile"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@android:color/white"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:text="9876543210"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ============= DEVICE CONTROL CARD ============= -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Device Control"
                            android:textColor="@color/color_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvLockStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_pill_unlocked"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:text="UNLOCKED"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLockDevice"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="LOCK"
                            android:textSize="13sp"
                            android:letterSpacing="0.05"
                            app:icon="@drawable/ic_lock"
                            app:iconGravity="textStart"
                            app:iconSize="18dp"
                            app:iconTint="@color/selector_btn_content_tint"
                            android:textColor="@color/selector_btn_content_tint"
                            app:backgroundTint="@color/selector_btn_lock_tint"
                            app:cornerRadius="12dp"
                            app:rippleColor="#33000000"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUnlockDevice"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="UNLOCK"
                            android:textSize="13sp"
                            android:letterSpacing="0.05"
                            app:icon="@drawable/ic_open_loans"
                            app:iconGravity="textStart"
                            app:iconSize="18dp"
                            app:iconTint="@color/selector_btn_content_tint"
                            android:textColor="@color/selector_btn_content_tint"
                            app:backgroundTint="@color/selector_btn_unlock_tint"
                            app:cornerRadius="12dp"
                            app:rippleColor="#33000000"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ============= DEVICE INFORMATION ============= -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Device Information"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvDeviceName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:text="Samsung M35"/>

                    <TextView
                        android:id="@+id/tvImei"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp"
                        android:text="IMEI: 123456789012345"/>

                    <TextView
                        android:id="@+id/tvOnlineStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:drawablePadding="6dp"
                        android:gravity="center_vertical"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:text="● Online"
                        android:textColor="@color/color_success"
                        android:drawableStart="@drawable/ic_dot_green"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/color_border"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_battery"
                            android:contentDescription="@null"/>

                        <TextView
                            android:id="@+id/tvBattery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:text="82%"/>

                        <ProgressBar
                            android:id="@+id/progressBattery"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:max="100"
                            android:progress="82"
                            android:progressTint="@color/color_success"
                            android:progressBackgroundTint="@color/color_border"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvLastSeen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="12sp"
                        android:text="Last seen: 2 min ago"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ============= LOCATION ============= -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Location"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvLatitude"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@color/color_surface_variant"
                            android:padding="10dp"
                            android:fontFamily="monospace"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:text="18.5204"/>

                        <TextView
                            android:id="@+id/tvLongitude"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:background="@color/color_surface_variant"
                            android:padding="10dp"
                            android:fontFamily="monospace"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:text="73.8567"/>

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewMap"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:layout_marginTop="12dp"
                        android:text="VIEW MAP"
                        android:textSize="13sp"
                        app:icon="@drawable/ic_map_pin"
                        app:iconTint="@color/primary"
                        app:iconSize="18dp"
                        android:textColor="@color/primary"
                        app:strokeColor="@color/primary"
                        app:cornerRadius="12dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ============= EMI INFORMATION ============= -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EMI Information"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Loan"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="12sp"/>

                            <TextView
                                android:id="@+id/tvTotalLoan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/color_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:text="₹5,00,000"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Paid"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="12sp"/>

                            <TextView
                                android:id="@+id/tvPaidAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/color_success_dark"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:text="₹1,50,000"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="12sp"/>

                            <TextView
                                android:id="@+id/tvPendingAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/color_danger_dark"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:text="₹1,00,000"/>

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ProgressBar
                            android:id="@+id/progressEmi"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="60"
                            android:progressTint="@color/color_success"
                            android:progressBackgroundTint="@color/color_border"/>

                        <TextView
                            android:id="@+id/tvEmiPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:text="60%"/>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/color_border"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_calendar"
                            android:contentDescription="@null"/>

                        <TextView
                            android:id="@+id/tvNextEmiDate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:text="Next EMI: 15 July 2026"/>

                        <TextView
                            android:id="@+id/tvPenalty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/color_warning"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:text="Penalty ₹500"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ============= QUICK ACTIONS ============= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCallCustomer"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="CALL"
                    android:textSize="13sp"
                    app:icon="@drawable/ic_phone"
                    app:iconTint="@color/color_success_dark"
                    app:iconSize="16dp"
                    android:textColor="@color/color_success_dark"
                    app:strokeColor="@color/color_success_dark"
                    app:cornerRadius="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendReminder"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="REMINDER"
                    android:textSize="13sp"
                    app:icon="@drawable/ic_reminder"
                    app:iconTint="@color/color_warning"
                    app:iconSize="16dp"
                    android:textColor="@color/color_warning"
                    app:strokeColor="@color/color_warning"
                    app:cornerRadius="12dp"/>

            </LinearLayout>

            <!-- ============= FEATURE CONTROLS ============= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Feature Controls"
                android:textColor="@color/color_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerFeatures"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:nestedScrollingEnabled="false"/>

            </androidx.cardview.widget.CardView>

            <!-- ============= RECENT COMMANDS ============= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Recent Commands"
                android:textColor="@color/color_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerCommands"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:nestedScrollingEnabled="false"/>

            </androidx.cardview.widget.CardView>

            <!-- ============= RETAILER NOTES ============= -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Retailer Notes"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvRetailerNotes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp"
                        android:text="Customer detail for Rahul Sharma"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>