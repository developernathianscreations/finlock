                    android:text="• Access their personal information\n• Request correction of inaccurate data\n• Request deletion of personal information\n• Withdraw consent where applicable\n\nRequests may be submitted through the contact details provided below."
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

