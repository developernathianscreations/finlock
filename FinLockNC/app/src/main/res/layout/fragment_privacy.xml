<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/screenBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ===== HEADER CARD ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/ic_lock"
                    app:tint="@android:color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Privacy Policy"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Your data security is our priority"
                    android:textColor="@color/headerText"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Last Updated: June 2026"
                    android:textColor="@color/headerText"
                    android:textSize="12sp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ===== INTRODUCTION ===== -->
        <TextView
            style="@style/SectionTitleStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Introduction"
            android:textColor="@color/textPrimary"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Welcome to Finlock NC. Finlock NC is a device management and EMI protection solution developed and operated by Nathians Creations Pvt. Ltd. This Privacy Policy explains how we collect, use, store, and protect information when you use our mobile applications, web portals, and related services. By using Finlock NC, you agree to the collection and use of information in accordance with this Privacy Policy."
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ===== SECTION 1: Information We Collect ===== -->
        <TextView
            style="@style/SectionTitleStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Information We Collect"
            android:textColor="@color/textPrimary"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Device Information"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Device model and manufacturer\n• Android or iOS version\n• Device identifiers\n• Application version\n• Network information"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Location Information"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="With your consent, Finlock NC may collect device location information to:\n\n• Track financed devices\n• Verify device status\n• Assist retailers in asset management\n• Improve security and fraud prevention\n\nLocation data is collected only for authorized business purposes."
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Account Information"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Customer name\n• Mobile number\n• Email address\n• Retailer details\n• Loan and EMI-related information"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Usage Information"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• App usage\n• Device status\n• Restricted applications\n• Lock and unlock activities\n• Security events"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ===== SECTION 2: How We Use Your Information ===== -->
        <TextView
            style="@style/SectionTitleStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How We Use Your Information"
            android:textColor="@color/textPrimary"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Finlock NC uses collected information to:"
                    android:textColor="@color/textPrimary"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Manage financed devices\n• Monitor EMI payment status\n• Enable remote device lock and unlock\n• Provide customer support\n• Improve application performance\n• Prevent fraud and misuse\n• Comply with legal and regulatory requirements"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ===== SECTION 3: Device Control Features ===== -->
        <TextView
            style="@style/SectionTitleStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device Control Features"
