<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ==================== HEADER ==================== -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@android:color/white">

                <!-- Maroon curved background on upper left side (only behind logo) -->
                <View
                    android:layout_width="110dp"
                    android:layout_height="60dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/bg_curved_maroon" />

                <!-- Logo on top of maroon curved background -->
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="50dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="24dp"
                    android:src="@drawable/logo_primary_back"
                    android:contentDescription="Finlock Icon"
                    android:padding="4dp" />

                <!-- Right side: App Version and English Language -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="16dp"
                    android:orientation="horizontal"
                    android:gravity="center">


                    <!-- Separator dot -->
                    <View
                        android:layout_width="3dp"
                        android:layout_height="3dp"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_dot_gray" />

                    <!-- English Language -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="English"
                            android:textColor="@color/primaryLight"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_arrow_down"
                            android:contentDescription="Dropdown" />
                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>

            <!-- ==================== USER GREETING ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hi, Krushna"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1E1E2A" />

                <!-- Login text -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Login"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primaryDark"
                    android:layout_marginEnd="12dp" />

            </LinearLayout>

            <!-- ==================== MPIN CARD ==================== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Login with mPIN"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#111111" />

                        <!-- Password Toggle Button -->
                        <ImageView
                            android:id="@+id/btnTogglePassword"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_eye_close"
                            android:contentDescription="Toggle Password Visibility" />
                    </LinearLayout>

                    <!-- 6-digit MPIN boxes -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/digit1"
                            android:layout_width="44dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_mpin_box"
                            android:gravity="center"
                            android:inputType="numberPassword"
                            android:maxLength="1"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:importantForAutofill="no" />

                        <EditText
                            android:id="@+id/digit2"
                            android:layout_width="44dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_mpin_box"
                            android:gravity="center"
                            android:inputType="numberPassword"
                            android:maxLength="1"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:importantForAutofill="no" />

                        <EditText
                            android:id="@+id/digit3"
                            android:layout_width="44dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_mpin_box"
                            android:gravity="center"
                            android:inputType="numberPassword"
                            android:maxLength="1"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:importantForAutofill="no" />

                        <EditText
                            android:id="@+id/digit4"
                            android:layout_width="44dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_mpin_box"
                            android:gravity="center"
                            android:inputType="numberPassword"
                            android:maxLength="1"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:importantForAutofill="no" />

                    </LinearLayout>

                    <!-- Forgot mPIN -->
                    <TextView
                        android:id="@+id/tvForgotMpin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_gravity="end"
                        android:text="Forgot mPIN"
                        android:textColor="@color/primaryLight"
                        android:textStyle="bold"
                        android:textSize="13sp" />

                    <!-- Login Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        android:text="LOGIN"
                        android:textAllCaps="true"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="24dp" />

                    <!-- Fingerprint -->
                    <LinearLayout
                        android:id="@+id/llFingerprint"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:background="@drawable/bg_fingerprint"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_fingerprint"
                            android:contentDescription="Fingerprint" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="USE FINGERPRINT"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:layout_marginStart="10dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

