<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="18dp"
    android:paddingTop="4dp"
    android:background="@color/primary">

    <!-- Step Label Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/tv_step_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Step 1 of 6"
            android:textColor="@color/headerText"
            android:textSize="12sp"
            android:letterSpacing="0.06" />

        <TextView
            android:id="@+id/tv_step_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customer Details"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Step Dots Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Step 1 Dot (active) -->
        <View
            android:id="@+id/dot_step1"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_step_dot_active" />

        <!-- Step 2 Dot -->
        <View
            android:id="@+id/dot_step2"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_step_dot_inactive" />

        <!-- Step 3 Dot -->
        <View
            android:id="@+id/dot_step3"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_step_dot_inactive" />

        <!-- Step 4 Dot -->
        <View
            android:id="@+id/dot_step4"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_step_dot_inactive" />

        <!-- Step 5 Dot -->
        <View
            android:id="@+id/dot_step5"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_step_dot_inactive" />

        <!-- Step 6 Dot -->
        <View
            android:id="@+id/dot_step6"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_step_dot_inactive" />

    </LinearLayout>

</LinearLayout>