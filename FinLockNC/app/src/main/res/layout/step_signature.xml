<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardSignature"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/cardWhite"
    app:strokeColor="@color/borderColor"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- Section Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="6"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_step_badge"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Digital Signature"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign to confirm application"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="1dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_sig_done"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ Done"
                android:textColor="@color/green"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/bg_done_badge"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Instruction text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Draw your signature in the box below. This confirms your consent for the loan application."
            android:textSize="13sp"
            android:textColor="@color/textSecondary"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="18dp"
            android:layout_marginStart="46dp" />

        <!-- Signature Canvas -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/borderColor"
            app:strokeWidth="1.5dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="14dp">

            <com.nc.finlocknc.custom.SignatureView
                android:id="@+id/signatureView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/white" />

            <!-- "Sign here" placeholder hint -->
            <TextView
                android:id="@+id/tv_signature_hint"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Sign here ✍"
                android:textColor="@color/borderColor"
                android:textSize="16sp"
                android:gravity="center"
                android:importantForAccessibility="no" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Signature Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearSignature"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="Clear"
                android:textColor="@color/red"
                android:textStyle="bold"
                app:icon="@drawable/ic_clear"
                app:iconTint="@color/red"
                app:strokeColor="@color/red"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveSignature"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="2"
                android:text="Save Signature"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:backgroundTint="@color/primary"
                app:icon="@drawable/ic_check"
                app:iconTint="@color/white"
                app:cornerRadius="12dp" />

        </LinearLayout>

        <!-- Signature Status Banner -->
        <LinearLayout
            android:id="@+id/layout_sig_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="10dp"
            android:background="@drawable/bg_sig_status_error">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_warning"
                android:contentDescription="Warning"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvSignatureStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Signature required to proceed"
                android:textSize="12sp"
                android:textColor="@color/red"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>