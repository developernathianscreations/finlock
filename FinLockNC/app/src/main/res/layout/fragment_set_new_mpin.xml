<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screenBackground">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:navigationIcon="@drawable/ic_arrow_back"
        android:paddingTop="10dp"
        app:navigationIconTint="@color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Set New MPIN"
        android:textColor="@color/white"
        android:textAppearance="@style/CustomToolbarTitle"
        android:textStyle="bold"
        android:paddingTop="5dp"
        android:layout_gravity="center_vertical"
        android:translationY="2dp"/>

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Top Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Content Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- App Logo -->
                <ImageView
                    android:id="@+id/logoIcon"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/logowhite_back"
                    android:contentDescription="App Logo"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="16dp" />

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set New MPIN"
                    style="@style/SectionTitleStyle"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="4dp" />

                <!-- Subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter your new 4-digit MPIN"
                    android:textSize="14sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginBottom="24dp" />

                <!-- New MPIN Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New MPIN"
                    android:textStyle="bold"
                    style="@style/SectionTitleStyle"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="12dp" />

                <!-- New MPIN Digit Boxes -->
                <LinearLayout
                    android:id="@+id/layoutNewMpinBoxes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <EditText
                        android:id="@+id/newDigit1"
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_mpin_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:importantForAutofill="no"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                    <EditText
                        android:id="@+id/newDigit2"
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_mpin_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:importantForAutofill="no" />

                    <EditText
                        android:id="@+id/newDigit3"
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_mpin_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:importantForAutofill="no" />

                    <EditText
                        android:id="@+id/newDigit4"
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_mpin_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:importantForAutofill="no" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="60dp"
                    android:layout_height="2dp"
                    android:background="@color/primary"
                    android:layout_marginBottom="24dp" />

                <!-- Confirm MPIN Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm MPIN"
                    android:textStyle="bold"
                    style="@style/SectionTitleStyle"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="12dp" />

                <!-- Confirm MPIN Digit Boxes -->
                <LinearLayout
                    android:id="@+id/layoutConfirmMpinBoxes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/confirmDigit1"
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_mpin_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:importantForAutofill="no" />

                    <EditText
                        android:id="@+id/confirmDigit2"
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_mpin_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:importantForAutofill="no" />

                    <EditText
                        android:id="@+id/confirmDigit3"
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_mpin_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:importantForAutofill="no" />

                    <EditText
                        android:id="@+id/confirmDigit4"
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_mpin_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:importantForAutofill="no" />

                </LinearLayout>

                <!-- Set New MPIN Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSetNewMpin"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="32dp"
                    android:text="SET NEW MPIN"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="16dp"
                    app:elevation="4dp" />

            </LinearLayout>

            <!-- Bottom Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>