<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screenBackground">

    <!-- TOP APP BAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        app:elevation="0dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:navigationIcon="@drawable/ic_arrow_back"
            android:paddingTop="10dp"
            app:navigationIconTint="@color/white">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Loan Application"
                android:textAppearance="@style/CustomToolbarTitle"
                android:paddingTop="5dp"
                android:layout_gravity="center_vertical"
                android:translationY="2dp"/>
        </com.google.android.material.appbar.MaterialToolbar>

        <!-- STEP PROGRESS INDICATOR -->
        <include layout="@layout/component_step_indicator" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- SCROLLABLE CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:paddingTop="15dp"
            android:paddingBottom="120dp">

            <!-- STEP 1: Customer Details -->
            <include
                android:id="@+id/step1_customer"
                layout="@layout/step_customer_details" />

            <!-- STEP 2: Address Info -->
            <include
                android:id="@+id/step2_address"
                layout="@layout/step_address_info" />

            <!-- STEP 3: Guarantor -->
            <include
                android:id="@+id/step3_guarantor"
                layout="@layout/step_guarantor_details" />

            <!-- STEP 4: Loan Details -->
            <include
                android:id="@+id/step4_loan"
                layout="@layout/step_loan_details" />

            <!-- STEP 5: Device Details -->
            <include
                android:id="@+id/step5_device"
                layout="@layout/step_device_details" />

            <!-- STEP 6: Documents -->
            <include
                android:id="@+id/step6_documents"
                layout="@layout/step_documents_upload" />

            <!-- STEP 7: Signature -->
            <include
                android:id="@+id/step7_signature"
                layout="@layout/step_signature" />
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- PROGRESS OVERLAY CONTAINER -->
    <FrameLayout
        android:id="@+id/progressContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:background="#66000000"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/CustomProgressBar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:background="@drawable/progressbar_background" />

    </FrameLayout>

    <!-- BOTTOM ACTION BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="16dp">

        <!-- Thin top border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/borderColor" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <!-- Back Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="Back"
                android:textColor="@color/primary"
                android:textStyle="bold"
                app:strokeColor="@color/primary"
                app:strokeWidth="1.5dp"
                app:cornerRadius="14dp" />

            <!-- Next / Submit Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="2"
                android:text="Continue"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:backgroundTint="@color/primary"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_arrow_forward"
                app:iconTint="@color/white"
                app:iconGravity="end" />

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>