<?xml version="1.0" encoding="utf-8"?>
<!-- Document upload tile - whole tile is clickable -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/btnUploadDoc"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:background="@drawable/bg_doc_tile_pending"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <!-- Document Icon Container -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="14dp">

        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:background="@drawable/bg_doc_icon_circle">

            <ImageView
                android:id="@+id/ivDocIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_document"
                android:contentDescription="Document" />

        </LinearLayout>

        <!-- Uploaded checkmark overlay -->
        <ImageView
            android:id="@+id/ivDocCheck"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="bottom|end"
            android:src="@drawable/ic_check_circle"
            android:contentDescription="Uploaded"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Text Section -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvDocTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PAN Card"
            android:textColor="#1A1A1A"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvDocStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to upload"
            android:textColor="#707070"
            android:textSize="12sp"
            android:layout_marginTop="3dp" />

    </LinearLayout>

    <!-- Right action icon -->
    <ImageView
        android:id="@+id/ivDocAction"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_upload_arrow"
        android:contentDescription="Upload"
        android:layout_marginStart="10dp" />

</LinearLayout>